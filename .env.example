# ===========================================
# MiroFish Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------- LLM Configuration ----------
# Supports any LLM API with OpenAI SDK format
# Recommended: Alibaba Bailian (qwen-plus): https://bailian.console.aliyun.com/
# High token consumption — start with <40 simulation rounds
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ---------- Zep Cloud (Memory) ----------
# Free tier is sufficient for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ---------- Neo4j (Optional — Knowledge Graph) ----------
# NEO4J_URI=neo4j://127.0.0.1:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password

# ---------- Flask Options ----------
# Use FLASK_DEBUG (not DEBUG) to control debug mode
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
